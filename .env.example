# ─── App ──────────────────────────────────────────────────
NODE_ENV=production
PORT=4000                          # Railway injects this automatically

# ─── Database (Railway MySQL plugin injects these) ─────────
DB_HOST=your-mysql-host.railway.internal
DB_PORT=3306
DB_NAME=zero_db
DB_USER=zero_user
DB_PASSWORD=changeme
DB_SSL=false                       # set true if Railway requires it

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64char_random_hex
JWT_REFRESH_SECRET=replace_with_another_64char_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Integration ──────────────────────────────────────────
INTEGRATION_PROVIDER=local         # local | tiendanube (tiendanube not yet implemented)

# ─── Rate limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── Frontend (local dev only — leave blank in Railway) ───
# When blank, API calls go to same origin (/api/...) — correct for Railway.
# Set this only when running frontend separately (npm run dev:frontend).
# NEXT_PUBLIC_API_URL=http://localhost:4000
