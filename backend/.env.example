# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zero_db
DB_USER=zero_user
DB_PASSWORD=changeme

# ─── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64char_random_string
JWT_REFRESH_SECRET=replace_with_another_64char_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── CORS ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Integration ───────────────────────────────────────
# "local" = mock data | "tiendanube" = real API (not implemented yet)
INTEGRATION_PROVIDER=local

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info
