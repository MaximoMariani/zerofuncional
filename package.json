{
  "name": "zero",
  "version": "1.0.0",
  "description": "ZERO - Sistema de armado de pedidos (single Railway service)",
  "main": "server/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "cd frontend && npm install && npm run build && node ../scripts/copy-build.js",
    "start": "node server/index.js",
    "migrate": "knex --knexfile server/db/knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile server/db/knexfile.js migrate:rollback",
    "seed": "knex --knexfile server/db/knexfile.js seed:run",
    "dev:server": "nodemon server/index.js",
    "dev:frontend": "cd frontend && NEXT_PUBLIC_API_URL=http://localhost:4000 npm run dev",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint server --ext .js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.6.5",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/tests/**/*.test.js"]
  }
}
