# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database (Railway Postgres) ──────────────────────────────
# Either a full URL (Railway provides DATABASE_URL automatically):
DATABASE_URL=postgresql://user:pass@host:5432/zero_db
# OR individual vars (DATABASE_URL takes precedence if set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zero_db
# DB_USER=zero_user
# DB_PASSWORD=changeme

# ── JWT ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption key for storing TN access tokens ──────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX

# ── Integration provider ─────────────────────────────────────
# "local"  = use seeded mock orders (dev/demo)
# "tiendanube" = live Tiendanube API
INTEGRATION_PROVIDER=local

# ── Tiendanube app credentials ───────────────────────────────
# Get these from Tiendanube Partners → My Apps
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=
# Must match what you register in the TN app settings:
TIENDANUBE_REDIRECT_URI=https://YOUR-APP.railway.app/api/integrations/tiendanube/auth/callback
# Arbitrary secret — set the same value in TN webhook config
TIENDANUBE_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── CORS ─────────────────────────────────────────────────────
# In production (same-origin), leave blank or set to Railway URL
ALLOWED_ORIGINS=http://localhost:3000

# ── Misc ──────────────────────────────────────────────────────
LOG_LEVEL=info
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20
