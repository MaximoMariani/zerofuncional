{
  "name": "zero",
  "version": "2.0.0",
  "description": "ZERO — Order packing system with Tiendanube integration",
  "main": "server/index.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build":           "cd frontend && npm install && npm run build && node ../scripts/copy-build.js",
    "start":           "node server/index.js",
    "dev:server":      "nodemon server/index.js",
    "dev:frontend":    "cd frontend && npm run dev",
    "migrate":         "knex --knexfile server/db/knexfile.js migrate:latest",
    "migrate:rollback":"knex --knexfile server/db/knexfile.js migrate:rollback",
    "seed":            "knex --knexfile server/db/knexfile.js seed:run",
    "test":            "jest --runInBand --forceExit",
    "lint":            "eslint server --ext .js"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet":             "^7.1.0",
    "joi":                "^17.12.2",
    "jsonwebtoken":       "^9.0.2",
    "knex":               "^3.1.0",
    "node-fetch":         "^2.7.0",
    "pg":                 "^8.11.5",
    "pino":               "^8.19.0",
    "pino-http":          "^9.0.0",
    "pino-pretty":        "^11.0.0",
    "uuid":               "^9.0.1"
  },
  "devDependencies": {
    "eslint":     "^8.57.0",
    "jest":       "^29.7.0",
    "nodemon":    "^3.1.0",
    "supertest":  "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/tests/**/*.test.js"]
  }
}
